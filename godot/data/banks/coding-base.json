{"schemaVersion":1,"subject":"coding","items":[{"id":"cod-1","prompt":"Quale simbolo indica un commento in GDScript?","format":"multiple_choice","options":["#","//","<!--"],"answer":"#","explanation":"In GDScript il commento inizia con #.","difficulty":1},{"id":"cod-2","prompt":"Cosa contiene una variabile?","format":"multiple_choice","options":["Un valore","Solo un colore","Un'immagine obbligatoria"],"answer":"Un valore","explanation":"Una variabile memorizza un valore.","difficulty":2},{"id":"cod-3","prompt":"Quale struttura ripete istruzioni?","format":"multiple_choice","options":["Ciclo","Titolo","Texture"],"answer":"Ciclo","explanation":"Un ciclo ripete un blocco di istruzioni.","difficulty":3}]}
